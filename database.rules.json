{
  "rules": {
    "users": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$uid": {
        ".read": "$uid === auth.uid || auth != null",
        ".write": "$uid === auth.uid || auth != null"
      }
    },
    "orders": {
      ".read": true,
      ".write": "auth != null"
    },
    "products": {
      ".read": true,
      ".write": "auth != null"
    },
    "reservations": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": [
        "uid",
        "date",
        "status"
      ]
    },
    "tables": {
      ".read": true,
      ".write": "auth != null"
    },
    "tableSlots": {
      ".read": true,
      ".write": "auth != null"
    },
    "reviews": {
      ".read": true,
      ".write": "auth != null"
    },
    "promotions": {
      ".read": true,
      ".write": "auth != null"
    },
    "siteSettings": {
      ".read": true,
      ".write": "auth != null"
    },
    "notifications": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "contacts": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "news": {
      ".read": true,
      ".write": "auth != null"
    }
  }
}